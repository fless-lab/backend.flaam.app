# ── App ──
APP_NAME=flaam
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=4
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# ── Sécurité ──
SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256
OTP_LENGTH=6
OTP_EXPIRE_SECONDS=600
OTP_MAX_ATTEMPTS=3
OTP_COOLDOWN_SECONDS=60

# ── Database ──
DATABASE_URL=postgresql+asyncpg://flaam:password@db:5432/flaam
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# ── Redis ──
REDIS_URL=redis://redis:6379/0
REDIS_FEED_DB=1
REDIS_CACHE_DB=2

# ── RabbitMQ / Celery ──
CELERY_BROKER_URL=amqp://flaam:password@rabbitmq:5672/flaam
CELERY_RESULT_BACKEND=redis://redis:6379/3

# ── Storage (Cloudflare R2) ──
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=change-me
R2_SECRET_ACCESS_KEY=change-me
R2_BUCKET_PHOTOS=flaam-photos
R2_BUCKET_VOICE=flaam-voice
CDN_BASE_URL=https://cdn.flaam.app

# ── SMS (Termii — unique provider MVP) ──
TERMII_API_KEY=change-me
TERMII_SENDER_ID=Flaam
TERMII_BASE_URL=https://api.ng.termii.com
TERMII_SANDBOX=false
# Dev mode : logue l'OTP au lieu d'appeler Termii (override complet)
SMS_SIMULATE=true

# ── Rate limiting OTP ──
RATE_LIMIT_OTP_PER_WINDOW=3
RATE_LIMIT_OTP_WINDOW_SECONDS=600

# ── Payment (Paystack) ──
PAYSTACK_SECRET_KEY=change-me
PAYSTACK_WEBHOOK_SECRET=change-me

# ── Firebase (Push notifications) ──
FCM_SERVICE_ACCOUNT_JSON=/secrets/fcm-service-account.json

# ── Matching engine ──
MATCHING_BATCH_HOUR=3
MATCHING_FEED_SIZE=12
MATCHING_WILDCARD_COUNT=2
MATCHING_NEW_USER_BOOST_DAYS=10
MATCHING_MATCH_EXPIRE_DAYS=7
MATCHING_SKIP_COOLDOWN_DAYS=30
MATCHING_MIN_WEEKLY_VISIBILITY=15

# ── Rate limiting ──
RATE_LIMIT_DEFAULT=60
RATE_LIMIT_PREMIUM=120
RATE_LIMIT_LIKES_FREE=5
RATE_LIMIT_LIKES_PREMIUM=50

# ── Sentry ──
SENTRY_DSN=
